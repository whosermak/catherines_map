generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id      Int     @id @unique @default(autoincrement())
  login   String  @unique
  pwd     String
  name    String
  f_name  String
  years   String
  desc    String
  avatar  String

  posts Post[]
}

model Post {
  id        Int     @id @unique @default(autoincrement())
  text      String  
  time      DateTime

  author    User    @relation(fields: [authorId], references: [id])
  authorId  Int

  parent    Post?   @relation("Replies", fields: [parentId], references: [id])
  replies   Post[]  @relation("Replies")
  parentId  Int?

  rootId    Int?

  @@index([parentId])
  @@index([rootId])
}